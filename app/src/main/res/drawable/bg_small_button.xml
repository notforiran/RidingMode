<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#5C6470" android:endColor="#3E4550" />
            <stroke android:width="1dp" android:color="#B8DCE6F5" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#4D5560" android:endColor="#343A43" />
            <stroke android:width="1dp" android:color="#8EA8B4C4" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
